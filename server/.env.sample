ALLOWED_ORIGIN=*
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
CONTEXT=/fileforge

# --- RS256 access-token signing (FileForge -> MailAnchor bridge, mailanchor.ui.0003 T1) ---
# Access tokens are signed RS256 so the Go server can verify them with the public key
# alone. Provide a private key inline (JWT_PRIVATE_KEY) or by path (JWT_PRIVATE_KEY_FILE).
# If neither is set, a keypair is generated and persisted under JWT_KEYS_DIR on first boot
# (jwt_private.pem + jwt_public.pem) — export jwt_public.pem to the Go server via
# MAILANCHOR_FILEFORGE_JWT_PUBKEY_FILE. iss/aud must match the Go server's
# MAILANCHOR_FILEFORGE_ISSUER / _AUDIENCE.
# JWT_PRIVATE_KEY=
# JWT_PRIVATE_KEY_FILE=./keys/jwt_private.pem
JWT_KEYS_DIR=./keys
JWT_ISSUER=fileforge
JWT_AUDIENCE=mailanchor
DB_PATH=./fileforge.db
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=0
DB_USER=
DB_PASSWORD=
DB_DATABASE=fileforge
DB_SCHEMA=

RATE_LIMIT_DEFAULT=1000/hour
RATE_LIMIT_LOGIN=50/minute
RATE_LIMIT_UPLOAD=1200/minute
RATE_LIMIT_DOWNLOAD=1200/minute

